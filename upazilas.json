<!DOCTYPE html>
<html lang="bn">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>বাংলাদেশ - বিভাগ, জেলা, উপজেলা, ইউনিয়ন</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', 'Hind Siliguri', sans-serif;
        }
        body {
            background: linear-gradient(145deg, #e0f2e9 0%, #c8e0d4 100%);
            min-height: 100vh;
            padding: 20px;
        }
        .container {
            max-width: 1200px;
            margin: 0 auto;
        }
        .card {
            background: white;
            border-radius: 28px;
            box-shadow: 0 20px 35px -12px rgba(0,0,0,0.15);
            overflow: hidden;
            margin-bottom: 24px;
        }
        .card-header {
            background: linear-gradient(95deg, #0a5c3b, #188c4a);
            color: white;
            padding: 20px 28px;
        }
        .card-header h1 {
            font-size: 1.6rem;
            font-weight: 600;
        }
        .card-header p {
            opacity: 0.9;
            margin-top: 5px;
            font-size: 0.9rem;
        }
        .card-body {
            padding: 25px 28px;
        }
        .form-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 20px;
            margin-bottom: 25px;
        }
        .form-group {
            display: flex;
            flex-direction: column;
        }
        label {
            font-weight: 700;
            color: #1a5a3a;
            margin-bottom: 8px;
            font-size: 0.85rem;
        }
        select {
            width: 100%;
            padding: 12px 16px;
            font-size: 0.95rem;
            border: 2px solid #d1e0d4;
            border-radius: 28px;
            background: white;
            font-weight: 500;
            cursor: pointer;
        }
        select:focus {
            outline: none;
            border-color: #188c4a;
        }
        select:disabled {
            background: #f4f9f6;
            cursor: not-allowed;
            opacity: 0.7;
        }
        .counter {
            font-size: 0.7rem;
            color: #4a6b5c;
            margin-top: 5px;
            margin-left: 10px;
        }
        .selected-info {
            background: #eef6f1;
            border-radius: 20px;
            padding: 14px 20px;
            margin-top: 20px;
            border-left: 5px solid #188c4a;
        }
        .badge {
            background: #188c4a;
            color: white;
            padding: 5px 15px;
            border-radius: 40px;
            font-weight: 600;
            font-size: 0.75rem;
            display: inline-block;
            margin-bottom: 8px;
        }
        .selected-text {
            font-weight: 600;
            color: #0f402c;
            font-size: 1rem;
        }
        .loading, .error-msg {
            padding: 12px;
            border-radius: 16px;
            margin-bottom: 20px;
            text-align: center;
        }
        .loading {
            background: #e0f7ea;
            color: #0f5236;
        }
        .error-msg {
            background: #ffe6e5;
            color: #a1221a;
            border-left: 5px solid #c7362b;
        }
        .items-list {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-top: 15px;
            max-height: 200px;
            overflow-y: auto;
        }
        .item-tag {
            background: #f0f7f3;
            border: 1px solid #bcddce;
            border-radius: 40px;
            padding: 5px 14px;
            font-size: 0.75rem;
            color: #1a5e3a;
        }
    </style>
</head>
<body>
<div class="container">
    <div class="card">
        <div class="card-header">
            <h1>🇧🇩 বাংলাদেশ প্রশাসনিক স্তর</h1>
            <p>JSON ফাইল থেকে লোড: বিভাগ → জেলা → উপজেলা → ইউনিয়ন</p>
        </div>
        <div class="card-body">
            <div id="loadStatus" class="loading">⏳ JSON ফাইল লোড হচ্ছে...</div>

            <div class="form-grid">
                <div class="form-group">
                    <label>📌 ১. বিভাগ</label>
                    <select id="divisionSelect" disabled>
                        <option value="">লোড হচ্ছে...</option>
                    </select>
                    <div class="counter" id="divisionCount"></div>
                </div>

                <div class="form-group">
                    <label>📍 ২. জেলা</label>
                    <select id="districtSelect" disabled>
                        <option value="">-- প্রথমে বিভাগ নির্বাচন --</option>
                    </select>
                    <div class="counter" id="districtCount"></div>
                </div>

                <div class="form-group">
                    <label>🗺️ ৩. উপজেলা</label>
                    <select id="upazilaSelect" disabled>
                        <option value="">-- প্রথমে জেলা নির্বাচন --</option>
                    </select>
                    <div class="counter" id="upazilaCount"></div>
                </div>

                <div class="form-group">
                    <label>🏘️ ৪. ইউনিয়ন</label>
                    <select id="unionSelect" disabled>
                        <option value="">-- প্রথমে উপজেলা নির্বাচন --</option>
                    </select>
                    <div class="counter" id="unionCount"></div>
                </div>
            </div>

            <div class="selected-info">
                <span class="badge">✔ বর্তমান নির্বাচন</span>
                <div class="selected-text" id="selectionDisplay">কোনো তথ্য নির্বাচিত হয়নি</div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header" style="background: #2a6e48;">
            <h3>📋 তালিকা (নির্বাচিত এলাকার অন্তর্ভুক্ত)</h3>
        </div>
        <div class="card-body">
            <div id="listContainer">
                <div class="items-list"><span class="item-tag">বিভাগ নির্বাচন করলে তালিকা দেখাবে</span></div>
            </div>
        </div>
    </div>
</div>

<script>
    // গ্লোবাল ডাটা
    let divisionsData = [];
    let districtsData = [];
    let upazilasData = [];
    let unionsData = [];

    // DOM এলিমেন্ট
    const divisionSelect = document.getElementById('divisionSelect');
    const districtSelect = document.getElementById('districtSelect');
    const upazilaSelect = document.getElementById('upazilaSelect');
    const unionSelect = document.getElementById('unionSelect');
    const selectionDisplay = document.getElementById('selectionDisplay');
    const loadStatusDiv = document.getElementById('loadStatus');
    const listContainer = document.getElementById('listContainer');

    // JSON ফাইল লোড ফাংশন
    async function loadJSON(url, fileName) {
        try {
            const response = await fetch(url);
            if (!response.ok) {
                throw new Error(`HTTP ${response.status}`);
            }
            const data = await response.json();
            // আপনার JSON ফাইলের ফরম্যাট অনুযায়ী
            if (Array.isArray(data)) return data;
            if (data && Array.isArray(data.data)) return data.data;
            return data;
        } catch (err) {
            throw new Error(`${fileName}: ${err.message}`);
        }
    }

    // সব ডাটা লোড করুন
    async function loadAllData() {
        try {
            loadStatusDiv.innerHTML = '⏳ divisions.json লোড হচ্ছে...';
            divisionsData = await loadJSON('divisions.json', 'divisions.json');
            
            loadStatusDiv.innerHTML = '⏳ districts.json লোড হচ্ছে...';
            districtsData = await loadJSON('districts.json', 'districts.json');
            
            loadStatusDiv.innerHTML = '⏳ upazilas.json লোড হচ্ছে...';
            upazilasData = await loadJSON('upazilas.json', 'upazilas.json');
            
            loadStatusDiv.innerHTML = '⏳ unions.json লোড হচ্ছে...';
            unionsData = await loadJSON('unions.json', 'unions.json');

            loadStatusDiv.innerHTML = `✅ সফল! ${divisionsData.length} বিভাগ, ${districtsData.length} জেলা, ${upazilasData.length} উপজেলা, ${unionsData.length} ইউনিয়ন লোড হয়েছে।`;
            loadStatusDiv.style.background = '#e0f7ea';
            
            populateDivisions();
            divisionSelect.disabled = false;
        } catch (error) {
            console.error(error);
            loadStatusDiv.innerHTML = `❌ লোড ব্যর্থ: ${error.message}<br><br>
            <strong>সমাধান:</strong> নিশ্চিত করুন যে নিচের ফাইলগুলো একই ফোল্ডারে আছে:<br>
            📄 divisions.json &nbsp; 📄 districts.json &nbsp; 📄 upazilas.json &nbsp; 📄 unions.json`;
            loadStatusDiv.style.background = '#ffe6e5';
        }
    }

    // বিভাগ ড্রপডাউন পপুলেট
    function populateDivisions() {
        divisionSelect.innerHTML = '<option value="">-- একটি বিভাগ নির্বাচন করুন --</option>';
        divisionsData.forEach(div => {
            const option = document.createElement('option');
            option.value = div.id;
            option.textContent = div.name;
            divisionSelect.appendChild(option);
        });
        document.getElementById('divisionCount').innerText = `মোট ${divisionsData.length}টি বিভাগ`;
    }

    // ফিল্টার ফাংশন
    function getDistrictsByDivision(divisionId) {
        return districtsData.filter(d => d.division_id == divisionId);
    }

    function getUpazilasByDistrict(districtId) {
        return upazilasData.filter(u => u.district_id == districtId);
    }

    function getUnionsByUpazila(upazilaId) {
        return unionsData.filter(u => u.upazila_id == upazilaId);
    }

    // জেলা আপডেট
    function updateDistricts(divisionId) {
        if (!divisionId) {
            districtSelect.innerHTML = '<option value="">-- প্রথমে বিভাগ নির্বাচন --</option>';
            districtSelect.disabled = true;
            upazilaSelect.innerHTML = '<option value="">-- প্রথমে জেলা নির্বাচন --</option>';
            upazilaSelect.disabled = true;
            unionSelect.innerHTML = '<option value="">-- প্রথমে উপজেলা নির্বাচন --</option>';
            unionSelect.disabled = true;
            document.getElementById('districtCount').innerText = '';
            document.getElementById('upazilaCount').innerText = '';
            document.getElementById('unionCount').innerText = '';
            listContainer.innerHTML = '<div class="items-list"><span class="item-tag">বিভাগ নির্বাচন করলে জেলার তালিকা দেখাবে</span></div>';
            return;
        }
        
        const filtered = getDistrictsByDivision(divisionId);
        districtSelect.innerHTML = '<option value="">-- একটি জেলা নির্বাচন করুন --</option>';
        filtered.forEach(dist => {
            const option = document.createElement('option');
            option.value = dist.id;
            option.textContent = dist.name;
            districtSelect.appendChild(option);
        });
        districtSelect.disabled = false;
        document.getElementById('districtCount').innerText = `মোট ${filtered.length}টি জেলা`;
        
        // জেলার তালিকা দেখান
        if (filtered.length > 0) {
            const tags = filtered.map(d => `<span class="item-tag">${d.name}</span>`).join('');
            listContainer.innerHTML = `<div class="items-list">${tags}</div>`;
        } else {
            listContainer.innerHTML = `<div class="items-list"><span class="item-tag">কোন জেলা নেই</span></div>`;
        }
        
        // রিসেট
        upazilaSelect.innerHTML = '<option value="">-- প্রথমে জেলা নির্বাচন --</option>';
        upazilaSelect.disabled = true;
        unionSelect.innerHTML = '<option value="">-- প্রথমে উপজেলা নির্বাচন --</option>';
        unionSelect.disabled = true;
        document.getElementById('upazilaCount').innerText = '';
        document.getElementById('unionCount').innerText = '';
    }

    // উপজেলা আপডেট
    function updateUpazilas(districtId) {
        if (!districtId) {
            upazilaSelect.innerHTML = '<option value="">-- প্রথমে জেলা নির্বাচন --</option>';
            upazilaSelect.disabled = true;
            unionSelect.innerHTML = '<option value="">-- প্রথমে উপজেলা নির্বাচন --</option>';
            unionSelect.disabled = true;
            document.getElementById('upazilaCount').innerText = '';
            document.getElementById('unionCount').innerText = '';
            return;
        }
        
        const filtered = getUpazilasByDistrict(districtId);
        upazilaSelect.innerHTML = '<option value="">-- একটি উপজেলা নির্বাচন করুন --</option>';
        filtered.forEach(up => {
            const option = document.createElement('option');
            option.value = up.id;
            option.textContent = up.name;
            upazilaSelect.appendChild(option);
        });
        upazilaSelect.disabled = false;
        document.getElementById('upazilaCount').innerText = `মোট ${filtered.length}টি উপজেলা`;
        
        // উপজেলার তালিকা দেখান
        if (filtered.length > 0) {
            const tags = filtered.map(u => `<span class="item-tag">${u.name}</span>`).join('');
            listContainer.innerHTML = `<div class="items-list">${tags}</div>`;
        } else {
            listContainer.innerHTML = `<div class="items-list"><span class="item-tag">কোন উপজেলা নেই</span></div>`;
        }
        
        // রিসেট ইউনিয়ন
        unionSelect.innerHTML = '<option value="">-- প্রথমে উপজেলা নির্বাচন --</option>';
        unionSelect.disabled = true;
        document.getElementById('unionCount').innerText = '';
    }

    // ইউনিয়ন আপডেট
    function updateUnions(upazilaId) {
        if (!upazilaId) {
            unionSelect.innerHTML = '<option value="">-- প্রথমে উপজেলা নির্বাচন --</option>';
            unionSelect.disabled = true;
            document.getElementById('unionCount').innerText = '';
            return;
        }
        
        const filtered = getUnionsByUpazila(upazilaId);
        unionSelect.innerHTML = '<option value="">-- একটি ইউনিয়ন নির্বাচন করুন --</option>';
        filtered.forEach(u => {
            const option = document.createElement('option');
            option.value = u.id;
            option.textContent = u.name;
            unionSelect.appendChild(option);
        });
        unionSelect.disabled = false;
        document.getElementById('unionCount').innerText = `মোট ${filtered.length}টি ইউনিয়ন`;
        
        // ইউনিয়নের তালিকা দেখান
        if (filtered.length > 0) {
            const tags = filtered.map(u => `<span class="item-tag">${u.name}</span>`).join('');
            listContainer.innerHTML = `<div class="items-list">${tags}</div>`;
        } else {
            listContainer.innerHTML = `<div class="items-list"><span class="item-tag">কোন ইউনিয়ন নেই</span></div>`;
        }
    }

    // নির্বাচন ডিসপ্লে আপডেট
    function updateSelectionDisplay() {
        const divisionId = divisionSelect.value;
        const districtId = districtSelect.value;
        const upazilaId = upazilaSelect.value;
        const unionId = unionSelect.value;
        
        const division = divisionsData.find(d => d.id == divisionId);
        const district = districtsData.find(d => d.id == districtId);
        const upazila = upazilasData.find(u => u.id == upazilaId);
        const union = unionsData.find(u => u.id == unionId);
        
        let text = '';
        if (division) text = `বিভাগ: ${division.name}`;
        if (district) text += ` → জেলা: ${district.name}`;
        if (upazila) text += ` → উপজেলা: ${upazila.name}`;
        if (union) text += ` → ইউনিয়ন: ${union.name}`;
        
        selectionDisplay.innerText = text || 'কোনো তথ্য নির্বাচিত হয়নি';
    }

    // ইভেন্ট লিসেনার
    divisionSelect.addEventListener('change', (e) => {
        updateDistricts(e.target.value);
        updateSelectionDisplay();
    });
    
    districtSelect.addEventListener('change', (e) => {
        updateUpazilas(e.target.value);
        updateSelectionDisplay();
    });
    
    upazilaSelect.addEventListener('change', (e) => {
        updateUnions(e.target.value);
        updateSelectionDisplay();
    });
    
    unionSelect.addEventListener('change', () => {
        updateSelectionDisplay();
    });

    // শুরু করুন
    loadAllData();
</script>
</body>
</html>